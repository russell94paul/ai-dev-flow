    if already_up:
        # Verify version matches the client before trusting the running server
        try:
            import importlib.metadata, json as _json
            client_ver = importlib.metadata.version('prefect')
            client_major = int(client_ver.split('.')[0])
            with urllib.request.urlopen('http://127.0.0.1:4200/api/version', timeout=2) as resp:

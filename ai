# -----------------------------
# Slug helper
# -----------------------------
make_slug() {
  local input="${1:-feature}"
  local slug
  slug=$(echo "$input" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-\|-$//g')
  if [[ -z "$slug" ]]; then
    slug="feature"
  fi
  echo "$slug"
}

# -----------------------------
# Shared helper: resolves notes_root, repo_slug, branch_name.
# Sets local vars in the caller's scope — must be called with 'local' vars
# already declared in the caller.
# -----------------------------
_resolve_notes_base() {
  if [[ -z "${AI_DEV_FLOW_NOTES_ROOT:-}" ]]; then
    echo "⚠️  AI_DEV_FLOW_NOTES_ROOT is not set — artifacts will land in the source repo."
    echo "   Set it in ~/ai-dev-flow/config.local to redirect notes to Obsidian."
  fi
  notes_root="${AI_DEV_FLOW_NOTES_ROOT:-$CALLER_DIR}"
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || repo_root="$CALLER_DIR"
  repo_slug=$(basename "$repo_root")
  branch_name=$(git -C "$repo_root" rev-parse --abbrev-ref HEAD 2>/dev/null) || branch_name="detached"
  if [[ "$branch_name" == "HEAD" ]]; then branch_name="detached"; fi
}

# -----------------------------
# Notes dir resolver — feature level
# Builds FEATURE_NOTES_DIR (POSIX) and FEATURE_NOTES_DIR_WIN (Windows)
# and pre-creates the standard subdirectory tree.
# -----------------------------
resolve_feature_notes_dir() {
  local feature_slug="$1"
  local notes_root repo_root repo_slug branch_name
  _resolve_notes_base

  FEATURE_NOTES_DIR="$notes_root/$repo_slug/$branch_name/features/$feature_slug"

  mkdir -p \
    "$FEATURE_NOTES_DIR/intake" \
    "$FEATURE_NOTES_DIR/discovery" \
    "$FEATURE_NOTES_DIR/specs" \
    "$FEATURE_NOTES_DIR/plans" \
    "$FEATURE_NOTES_DIR/build" \
    "$FEATURE_NOTES_DIR/qa"

  if command -v cygpath &>/dev/null; then
    FEATURE_NOTES_DIR_WIN=$(cygpath -w "$FEATURE_NOTES_DIR")
  else
    FEATURE_NOTES_DIR_WIN="$FEATURE_NOTES_DIR"
  fi
}

# -----------------------------
# Notes dir resolver — project level
# Builds FEATURES_BASE_POSIX and FEATURES_BASE_WIN pointing at
# <notes_root>/<repo>/<branch>/features — the root under which every
# feature slug gets its own subfolder.  The features/ dir is pre-created;
# per-slug subdirs (intake/ etc.) are created by Claude at write time.
# -----------------------------
resolve_project_notes_dir() {
  local notes_root repo_root repo_slug branch_name
  _resolve_notes_base

  FEATURES_BASE_POSIX="$notes_root/$repo_slug/$branch_name/features"

  mkdir -p "$FEATURES_BASE_POSIX"

  if command -v cygpath &>/dev/null; then
    FEATURES_BASE_WIN=$(cygpath -w "$FEATURES_BASE_POSIX")
  else
    FEATURES_BASE_WIN="$FEATURES_BASE_POSIX"
  fi
}

# -----------------------------
# New helper functions
# -----------------------------

# resolve_branch_root — sets BRANCH_ROOT_POSIX, BRANCH_ROOT_WIN,
# MANIFEST_PATH, MANIFEST_PATH_WIN
resolve_branch_root() {
  local notes_root repo_root repo_slug branch_name
  _resolve_notes_base
  BRANCH_ROOT_POSIX="$notes_root/$repo_slug/$branch_name"
  MANIFEST_PATH="$BRANCH_ROOT_POSIX/devflow.yaml"
  mkdir -p "$BRANCH_ROOT_POSIX"
  if command -v cygpath &>/dev/null; then
    BRANCH_ROOT_WIN=$(cygpath -w "$BRANCH_ROOT_POSIX")
    MANIFEST_PATH_WIN=$(cygpath -w "$MANIFEST_PATH")
  else
    BRANCH_ROOT_WIN="$BRANCH_ROOT_POSIX"
    MANIFEST_PATH_WIN="$MANIFEST_PATH"
  fi
}

# require_python — errors if python3 (or python) not on PATH.
# On Windows/Git Bash, python3 may only exist as an alias; we also accept
# 'python' if it runs Python 3. Sets PYTHON3 var for heredocs to use.
require_python() {
  if command -v python3 &>/dev/null; then
    PYTHON3="python3"
  elif command -v python &>/dev/null; then
    PYTHON3="python"
  else
    echo "❌ python3 is required but not found on PATH."
    exit 1
  fi
}

# require_manifest — errors if manifest doesn't exist
require_manifest() {
  if [[ ! -f "$MANIFEST_PATH" ]]; then
    echo "❌ No manifest found—run ai init"
    exit 1
  fi
}

# generate_evidence — generates qa/evidence.md for a feature slug
generate_evidence() {
  local feature_slug="$1"
  MANIFEST_PATH="$MANIFEST_PATH" \
  FEATURE_NOTES_DIR="$FEATURE_NOTES_DIR" \
  FEATURE_SLUG="$feature_slug" \
  $PYTHON3 - <<'PYEOF'
import os, json, hashlib, yaml
from pathlib import Path
from datetime import datetime, timezone

manifest_path = os.environ['MANIFEST_PATH']
feature_notes_dir = Path(os.environ['FEATURE_NOTES_DIR'])
feature_slug = os.environ['FEATURE_SLUG']

state_path = feature_notes_dir / 'state.json'
evidence_path = feature_notes_dir / 'qa' / 'evidence.md'
evidence_path.parent.mkdir(parents=True, exist_ok=True)

# Load manifest
with open(manifest_path, 'r') as f:
  manifest = yaml.safe_load(f)

# Load state
state = {}
if state_path.exists():
  with open(state_path, 'r') as f:
    state = json.load(f)

# Compute manifest sha256
with open(manifest_path, 'rb') as f:
  manifest_sha = hashlib.sha256(f.read()).hexdigest()

# Artifact paths
prd_path = feature_notes_dir / 'specs' / 'prd.md'
plan_path = feature_notes_dir / 'plans' / 'plan.md'
diagram_path = feature_notes_dir / 'specs' / 'diagram.md'

lines = [
  f'# Evidence: {feature_slug}',
  f'',
  f'**Generated:** {datetime.now(timezone.utc).isoformat()}Z',
  f'**Manifest SHA256:** `{manifest_sha}`',
  f'',
  f'## Artifacts',
  f'',
  f'| Artifact | Path | Exists |',
  f'|----------|------|--------|',
  f'| PRD | {prd_path} | {"yes" if prd_path.exists() else "no"} |',
  f'| Plan | {plan_path} | {"yes" if plan_path.exists() else "no"} |',
  f'| Diagram | {diagram_path} | {"yes" if diagram_path.exists() else "no"} |',
  f'',
  f'## QA Suites',
  f'',
  f'| Suite | Status | Artifact |',
  f'|-------|--------|----------|',
]

qa_suites = manifest.get('qa', {}).get('suites', [])
qa_state = state.get('qa', {})
for suite in qa_suites:
  name = suite.get('name', '')
  artifact_tmpl = suite.get('artifact', '')
  artifact = artifact_tmpl.replace('%slug%', feature_slug)
  slug_key = name.lower().replace(' ', '-')
  status = qa_state.get(slug_key, 'pending')
  lines.append(f'| {name} | {status} | {artifact} |')

lines += [
  f'',
  f'## Prefect Run',
  f'',
  f'**Status:** {state.get("qa", {}).get("prefect-run", "pending")}',
  f'',
  f'## Deploy',
  f'',
  f'**Status:** {state.get("deploy", {}).get("status", "pending")}',
]

evidence_path.write_text('\n'.join(lines) + '\n')
print(f'✅ Evidence written to {evidence_path}')
PYEOF
}


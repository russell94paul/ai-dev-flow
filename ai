def extract_flow_info(py_file):
    try:
        content = py_file.read_text(encoding='utf-8')
    except Exception:
        return None
    match = re.search(r'@(?:\w+\.)*(?:register_flow|flow)\b[^\n]*\nasync\s+def\s+(\w+)', content)
    if not match:
        match = re.search(r'@(?:\w+\.)*(?:register_flow|flow)\b[^\n]*\ndef\s+(\w+)', content)
    if not match:
        return None
    fn_name = match.group(1)
    is_async = bool(re.search(r'async\s+def\s+' + re.escape(fn_name), content))
    try:
        rel = py_file.relative_to(caller_dir)
    except ValueError:
        return None
    module = str(rel).replace('\\', '/').replace('/', '.').removesuffix('.py')
    if is_async:
        cmd = f'python -c "import asyncio; from {module} import {fn_name}; asyncio.run({fn_name}())"'
    else:
        cmd = f'python -c "from {module} import {fn_name}; {fn_name}()"'
    return {'file': str(rel).replace('\\', '/'), 'fn': fn_name, 'cmd': cmd}


    with open(state_path, 'r') as f:
        state = json.load(f)
if 'qa' not in state:
    state['qa'] = {}

prefect_cfg = manifest.get('prefect', {})
all_ok = True

# 1. Start sandbox if configured
sandbox_cmd = prefect_cfg.get('sandbox_start', '')
if sandbox_cmd:
    print(f'Starting Prefect sandbox: {sandbox_cmd}')
    result = subprocess.run(sandbox_cmd, shell=True, capture_output=True, text=True)
    if result.returncode != 0:
        print(f'❌ Sandbox start failed:\n{result.stderr}')
        all_ok = False

# 2. Check services health
for svc in manifest.get('services', []):
    health_cmd = svc.get('health', '')
    if health_cmd:
        h = subprocess.run(health_cmd, shell=True, capture_output=True, text=True)
        icon = '✅' if h.returncode == 0 else '❌'
        print(f'{icon} Service health ({svc.get("name", "")}): exit {h.returncode}')
        if h.returncode != 0:
            all_ok = False

# 3. Run Prefect flow
run_cmd = prefect_cfg.get('run_command', '')
run_out = ''
if run_cmd:
    print(f'Running Prefect flow: {run_cmd}')
    result = subprocess.run(run_cmd, shell=True, capture_output=True, text=True)
    run_out = result.stdout
    prefect_run_md = feature_notes_dir / 'qa' / 'prefect-run.md'
    prefect_run_md.parent.mkdir(parents=True, exist_ok=True)
    lines = [
        f'# Prefect Run: {feature_slug}',
        f'',
        f'**Timestamp:** {datetime.now(timezone.utc).isoformat()}Z',
        f'**Command:** `{run_cmd}`',
        f'**Exit code:** {result.returncode}',
        f'',
        f'## Output',
        f'',
        f'```',
        result.stdout.strip(),
        f'```',
    ]
    if result.stderr.strip():
        lines += [f'', f'## Stderr', f'', f'```', result.stderr.strip(), f'```']
    prefect_run_md.write_text('\n'.join(lines) + '\n')
    icon = '✅' if result.returncode == 0 else '❌'
    print(f'{icon} Prefect run → exit {result.returncode}')
    if result.returncode != 0:
        all_ok = False


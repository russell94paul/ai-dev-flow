    name = assertion.get('name', '')
    cmd = assertion.get('command', '')
    artifact_tmpl = assertion.get('artifact', '')
    artifact_rel = artifact_tmpl.replace('%slug%', feature_slug)
    artifact_path = branch_root / artifact_rel
    artifact_path.parent.mkdir(parents=True, exist_ok=True)

    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    passed = result.returncode == 0
    icon = '✅' if passed else '❌'
    assertion_lines += [
        f'## {name}',
        f'',
        f'**Command:** `{cmd}`',
        f'**Status:** {"pass" if passed else "fail"}',
        f'```',
        result.stdout.strip(),
        f'```',
        f'',
    ]
    print(f'{icon} Assertion {name}: {"pass" if passed else "fail"}')
    if not passed:
        all_ok = False

assertions_md = feature_notes_dir / 'qa' / 'assertions.md'
assertions_md.parent.mkdir(parents=True, exist_ok=True)
assertions_md.write_text('\n'.join(assertion_lines) + '\n')


        prefect_block['sandbox_start'] = prefect_sandbox
    if prefect_run:
        prefect_block['run_command'] = prefect_run
    prefect_block['assertions'] = [
        {
            'name': 'rows_emitted',
            'command': 'python scripts/assert_rows.py --min 10',
            'artifact': 'features/%slug%/qa/assertions.md',
        }

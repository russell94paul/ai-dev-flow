#!/usr/bin/env bash

set -euo pipefail

CALLER_DIR=$(pwd)
SKILL_DIR="$HOME/ai-dev-flow/skills"
AHK_SCRIPT="C:\\Users\\PaulRussell\\ai-dev-flow\\claude_paste.ahk"
CLAUDE_CMD="C:\\Users\\PaulRussell\\AppData\\Roaming\\npm\\claude.cmd"

# -----------------------------
# Validate input
# -----------------------------
if [ $# -lt 1 ]; then
  echo "Usage: ai <feature|tdd|new-project|skill-name> [context]"
  exit 1
fi

QUERY="$1"
shift
CONTEXT="$*"

# -----------------------------
# Slug helper
# -----------------------------
make_slug() {
  local input="${1:-feature}"
  local slug
  slug=$(echo "$input" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-\|-$//g')
  if [[ -z "$slug" ]]; then
    slug="feature"
  fi
  echo "$slug"
}

# -----------------------------
# Mode detection
# -----------------------------
if [[ "$QUERY" == "feature" ]]; then
  MODE="feature"
elif [[ "$QUERY" == "new-project" ]]; then
  MODE="new-project"
elif [[ "$QUERY" == "tdd" ]]; then
  MODE="tdd"
else
  MODE="single"
fi

# Default stage (overridden in each branch)
STAGE="[AI]"

# -----------------------------
# FEATURE MODE
# -----------------------------
if [[ "$MODE" == "feature" ]]; then

  FEATURE_SLUG=$(make_slug "${CONTEXT:-feature}")

  GRILL=$(cat "$SKILL_DIR/grill-me/SKILL.md")
  PRD=$(cat "$SKILL_DIR/write-a-prd/SKILL.md")
  PLAN=$(cat "$SKILL_DIR/prd-to-plan/SKILL.md")

  OUTPUT="================================
[FEATURE WORKFLOW]
================================

You are an expert software engineer following a structured development workflow.

You will guide the user through phases 1–3 of the feature lifecycle: GRILL → PRD → PLAN.
TDD implementation runs separately via the Claude Code CLI after this session completes.

---

## STEP 1: GRILL (Clarify requirements)

$GRILL

---

## STEP 2: WRITE PRD

Produce a clean, structured Product Requirements Document using markdown.

The PRD must include:
- Overview
- Goals
- Functional requirements
- Non-functional requirements
- Edge cases
- Success criteria

$PRD

---

## STEP 3: CREATE IMPLEMENTATION PLAN

Break the PRD into a phased implementation plan using vertical slices (tracer bullets).

Requirements:
- Use phases with acceptance-criteria checklists
- Each phase must be a thin vertical slice (end-to-end, demoable)
- Each acceptance criterion must be small and testable
- Avoid vague steps; no specific file names or function names

$PLAN

---

## WORKFLOW EXECUTION RULES

You MUST follow this process strictly:

### Phase 1: GRILL
- Ask one question at a time
- Do NOT proceed until user answers
- When done, say: \"GRILL COMPLETE\"

### Phase 2: PRD
- Produce a structured PRD
- Ask for confirmation before continuing
- Wait for user approval

### Phase 3: PLAN
- Break PRD into phases with acceptance-criteria checklists
- Ask for confirmation before continuing

### CRITICAL RULES
- NEVER skip phases
- NEVER assume missing information
- ALWAYS wait for user confirmation between phases
- ALWAYS state current phase clearly

---

## FILE OUTPUT REQUIREMENTS

You are working inside the user's project repository (the directory where they ran this command).

### After PRD phase:
- Create directory ./$FEATURE_SLUG/ if it does not exist
- Save the PRD to ./$FEATURE_SLUG/PRD.md
- Use clean markdown formatting
- Confirm the exact path to the user

### After PLAN phase:
- Save the implementation plan to ./$FEATURE_SLUG/plan.md
- Format as phases with acceptance-criteria checklists
- Confirm the exact path to the user
- Then print exactly: PLAN COMPLETE. To begin TDD run: ai tdd \"$FEATURE_SLUG\"

### Execution rules:
- Use available file tools to write files
- Confirm file creation to the user
- Do not skip saving files

---

## REPO CONTEXT

- You are working inside a real code repository
- Use relative paths from the current working directory (where the user ran \`ai feature\`)
- The feature folder is: ./$FEATURE_SLUG/

User request:
$CONTEXT"

  STAGE="[FEATURE]"

# -----------------------------
# NEW-PROJECT MODE
# -----------------------------
elif [[ "$MODE" == "new-project" ]]; then

  NEW_PROJECT=$(cat "$SKILL_DIR/new-project/SKILL.md")

  OUTPUT="================================
[NEW-PROJECT WORKFLOW]
================================

$NEW_PROJECT

---

User request:
$CONTEXT"

  STAGE="[NEW-PROJECT]"

# -----------------------------
# TDD MODE (Claude Code CLI)
# -----------------------------
elif [[ "$MODE" == "tdd" ]]; then

  FEATURE_SLUG=$(make_slug "${CONTEXT:-}")

  if [[ -z "$FEATURE_SLUG" ]]; then
    echo "❌ Usage: ai tdd <feature-slug>"
    exit 1
  fi

  PLAN_PATH="$CALLER_DIR/$FEATURE_SLUG/plan.md"

  if [[ ! -f "$PLAN_PATH" ]]; then
    echo "❌ No plan found at ./$FEATURE_SLUG/plan.md"
    echo "   Run 'ai feature \"<idea>\"' first to generate a plan."
    exit 1
  fi

  PLAN_CONTENT=$(cat "$PLAN_PATH")
  GUARDRAILS=$(cat "$SKILL_DIR/git-guardrails-claude-code/SKILL.md")
  TDD=$(cat "$SKILL_DIR/tdd/SKILL.md")

  OUTPUT="## GIT GUARDRAILS — CRITICAL

You are operating in a user's repository via Claude Code CLI.

NEVER run any of the following without explicit written user confirmation:
- git commit
- git push (any form)
- git reset --hard
- git clean
- git checkout -- (discarding changes)
- git branch -D

Before ANY git command:
1. State the exact command and why.
2. Wait for the user to confirm (\"yes\" or \"confirmed\").
3. Only then execute.

If hooks fail, fix the underlying cause — never use --no-verify.

---

$GUARDRAILS

---

$TDD

---

## Implementation Plan

$PLAN_CONTENT

---

## TDD OUTPUT REQUIREMENTS

### Console output

Keep the terminal quiet during TDD. Per cycle, print only:
- The test name and RED/GREEN status (one line each)
- Any compiler/runner error that requires user input

When all phases are complete, print this single summary line and nothing else:

  TDD COMPLETE — summary saved to ./$FEATURE_SLUG/tdd-summary.md (tests: N GREEN)

Replace N with the actual passing test count. Do NOT stream full test output, file diffs, or detailed tables to the console.

### Summary file

Write the full TDD record to ./$FEATURE_SLUG/tdd-summary.md immediately before printing the console summary. Overwrite if the file exists. Use this exact template:

\`\`\`markdown
# TDD Summary: $FEATURE_SLUG

**Timestamp:** <ISO 8601 timestamp>
**Plan source:** ./$FEATURE_SLUG/plan.md

## Phases completed

| Phase | Description | Status |
|-------|-------------|--------|
| Phase 1 | <title from plan> | ✅ GREEN |

## Test results

| # | Test description | Status |
|---|-----------------|--------|
| 1 | <behavior tested> | ✅ GREEN |

**Total: N GREEN, N RED**

## Files touched

- \`<relative path>\` — created / modified

## Commands run

\`\`\`
<exact commands used to run tests>
\`\`\`

## Design notes

- <any decisions, surprises, or tradeoffs made during implementation>
\`\`\`

Fill every section with real data from the session. Do not leave placeholder text."

  STAGE="[TDD]"

  # Write the full prompt to a temp file. Claude Code (Ink) requires an
  # interactive TTY so we can't pipe via stdin. The @file syntax lets Claude
  # Code load the prompt as the first message when pasted.
  PROMPT_FILE="/tmp/devflow-tdd-${FEATURE_SLUG}.md"
  echo "$OUTPUT" > "$PROMPT_FILE"

  # Put the @file reference in the clipboard. AHK will paste this into the
  # new Claude Code window — same flow as feature/new-project.
  if echo "@${PROMPT_FILE}" | clip.exe 2>/dev/null; then
    CLIP_OK=true
  else
    CLIP_OK=false
    echo "⚠️  Clipboard copy failed. Paste manually: @${PROMPT_FILE}"
  fi

  echo ""
  echo "🤖 Mode: $MODE"
  echo "🎯 Stage: $STAGE"
  echo "📋 Plan: $PLAN_PATH"
  echo "📝 Prompt: $PROMPT_FILE"
  echo "🚀 Opening Claude Code..."

  # Open a new Claude Code window (same as other modes).
  powershell.exe -NoProfile -Command "Start-Process '$CLAUDE_CMD'"

  # Wait for the window to be ready, then AHK-paste the @file message.
  sleep 6
  echo "⌨️ Sending prompt..."
  powershell.exe -Command "& '$AHK_SCRIPT' 'tdd'"

  echo "✅ Done. Claude Code should now be loading the TDD context."
  echo ""
  if [[ "$CLIP_OK" == false ]]; then
    echo "⚠️  Clipboard failed — if AHK missed, paste manually in Claude Code:"
    echo "   @${PROMPT_FILE}"
  else
    echo "   Fallback: if AHK missed, paste manually in Claude Code:"
    echo "   @${PROMPT_FILE}"
  fi
  exit 0

# -----------------------------
# SINGLE SKILL MODE
# -----------------------------
else

  # Determine workflow stage
  case "$QUERY" in
    grill*) STAGE="[GRILL]" ;;
    write-a-prd*) STAGE="[PRD]" ;;
    prd-to-plan*) STAGE="[PLAN]" ;;
    tdd*) STAGE="[TDD]" ;;
    triage*) STAGE="[TRIAGE]" ;;
    *) STAGE="[AI]" ;;
  esac

  # Find matching skill
  MATCH=$(find "$SKILL_DIR" -mindepth 1 -maxdepth 1 -type d \
    | grep -i "/[^/]*$QUERY[^/]*$" \
    | head -n 1 || true)

  if [ -z "$MATCH" ]; then
    echo "❌ Skill not found: $QUERY"
    echo ""
    echo "Available skills:"
    find "$SKILL_DIR" -mindepth 1 -maxdepth 1 -type d | while read -r d; do basename "$d"; done | sort
    exit 1
  fi

  OUTPUT=$(cat "$MATCH/SKILL.md")

  # Add visible workflow header
  OUTPUT="================================
$STAGE WORKFLOW
================================

$OUTPUT"

  if [ -n "$CONTEXT" ]; then
    OUTPUT="$OUTPUT

----
User context:
$CONTEXT"
  fi

fi

# -----------------------------
# Copy to clipboard
# -----------------------------
echo "$OUTPUT" | clip.exe

echo ""
echo "🤖 Mode: $MODE"
echo "🎯 Stage: $STAGE"
echo "📋 Prompt copied to clipboard"

# -----------------------------
# Launch Claude GUI
# -----------------------------
echo "🚀 Opening Claude..."

powershell.exe -NoProfile -Command "Start-Process '$CLAUDE_CMD'"

# -----------------------------
# Wait for Claude to open
# -----------------------------
sleep 6

# -----------------------------
# Trigger AutoHotkey paste
# -----------------------------
echo "⌨️ Sending prompt..."

powershell.exe -Command "& '$AHK_SCRIPT' '$QUERY'"

echo "✅ Done. Claude should now be running your workflow."

# -----------------------------
# Feature handoff reminder
# -----------------------------
if [[ "$MODE" == "feature" ]]; then
  echo ""
  echo "When PLAN phase is confirmed, run:"
  echo "  ai tdd \"$FEATURE_SLUG\""
fi
